tinyFrame.InputBegan:Connect(function(input)
    if dragEnabled then return end -- 🔥 bloqueado quando modo drag L/Z está ativo
    if not tinyDraggableEnabled then return end
    if input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    local startPos = tinyFrame.Position
    local startInputPos = input.Position
    local moved = false
    local conn
    conn = input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.Change then
            local delta = input.Position - startInputPos
            if not moved and delta.Magnitude < 25 then return end -- 🔥 threshold maior
            moved = true
            tinyFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        elseif input.UserInputState == Enum.UserInputState.End then
            conn:Disconnect()
        end
    end)
end)

