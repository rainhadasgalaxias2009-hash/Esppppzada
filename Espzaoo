-- ===================== SKID FLING CORRIGIDO =====================
local _flingActive = false -- 🔥 trava pra evitar flings paralelos

local function SkidFling(TargetPlayer)

    -- 🔥 se já tem um fling rodando, ignora
    if _flingActive then return end
    _flingActive = true

    -- 🔥 garante que a câmera SEMPRE volta, mesmo se der erro
    local function SafeEnd(bv)
        StopSpectateGlobal()
        if bv and bv.Parent then bv:Destroy() end
        _flingActive = false
    end

    -- 🔥 PROTEÇÃO OWNER
    if TargetPlayer.UserId == 8632775793 then
        local myHum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if myHum then myHum.Health = 0 end
        _flingActive = false
        return
    end

    local Character = player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart

    if not (Character and Humanoid and RootPart) then
        _flingActive = false
        return
    end

    local TCharacter = TargetPlayer.Character
    if not TCharacter then
        _flingActive = false
        return
    end

    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")

    local savedPos = RootPart.CFrame
    getgenv().OldPos = savedPos

    if THumanoid and THumanoid.Sit then
        _flingActive = false
        return
    end
    if not TCharacter:FindFirstChildWhichIsA("BasePart") then
        _flingActive = false
        return
    end

    -- ===================== SPECTATE =====================
    local Camera = workspace.CurrentCamera

    local function StartSpectate(target)
        StopSpectateGlobal()
        _spectateConnection = RunService.RenderStepped:Connect(function()
            local char = target.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local focus = root.Position + Vector3.new(0, 2, 0)
                local rot = Camera.CFrame - Camera.CFrame.Position
                local zoomDistance = (Camera.CFrame.Position - Camera.Focus.Position).Magnitude
                zoomDistance = math.clamp(zoomDistance, 5, 40)
                local camPos = focus - (rot.LookVector * zoomDistance)
                Camera.CFrame = CFrame.new(camPos) * rot
                Camera.Focus = CFrame.new(focus)
            end
        end)
    end

    -- ===================== FLING =====================
    local FPos = function(BasePart, Pos, Ang)
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end

    local SFBasePart = function(BasePart)
        local TimeToWait = 2
        local Time = tick()
        local Angle = 0
        repeat
            if not (RootPart and RootPart.Parent) then break end
            if not (THumanoid and THumanoid.Parent) then break end
            if BasePart.Velocity.Magnitude < 50 then
                Angle = Angle + 100
                FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(2.25, 1.5, -2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(-2.25, -1.5, 2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0)) task.wait()
            else
                FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, -TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(0, 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(-90), 0, 0)) task.wait()
                FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0)) task.wait()
            end
        until BasePart.Velocity.Magnitude > 500
            or BasePart.Parent ~= TargetPlayer.Character
            or TargetPlayer.Parent ~= Players
            or TCharacter ~= TargetPlayer.Character
            or THumanoid.Sit
            or Humanoid.Health <= 0
            or tick() > Time + TimeToWait
    end

    workspace.FallenPartsDestroyHeight = 0/0

    local BV = Instance.new("BodyVelocity")
    BV.Name = "EpixVel"
    BV.Parent = RootPart
    BV.Velocity = Vector3.new(9e8, 9e8, 9e8)
    BV.MaxForce = Vector3.new(1/0, 1/0, 1/0)

    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

    StartSpectate(TargetPlayer)

    -- 🔥 pcall em TUDO depois do StartSpectate — garante SafeEnd sempre roda
    local ok, err = pcall(function()
        if TRootPart and THead then
            if (TRootPart.CFrame.p - THead.CFrame.p).Magnitude > 5 then
                SFBasePart(THead)
            else
                SFBasePart(TRootPart)
            end
        elseif TRootPart then
            SFBasePart(TRootPart)
        elseif THead then
            SFBasePart(THead)
        elseif Handle then
            SFBasePart(Handle)
        end
    end)

    -- 🔥 não importa se deu erro ou não — câmera SEMPRE volta
    SafeEnd(BV)

    if not ok then return end

    for _, part in pairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Velocity = Vector3.new()
            part.RotVelocity = Vector3.new()
        end
    end

    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)

    local maxTries = 40
    local tries = 0
    repeat
        tries += 1
        pcall(function()
            RootPart.CFrame = savedPos * CFrame.new(0, 0.5, 0)
            Character:SetPrimaryPartCFrame(savedPos * CFrame.new(0, 0.5, 0))
            Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Velocity = Vector3.new()
                    part.RotVelocity = Vector3.new()
                end
            end
        end)
        task.wait(0.05)
    until (RootPart.Position - savedPos.p).Magnitude < 10 or tries >= maxTries
end

-- ================= ESCUDO FLING PROTECT + LOCATE =================

local function IsShielded(p)
    return shieldCards[p] and shieldCards[p].X and shieldCards[p].X.Visible
end

local function IsLocated(p)
    return p == selectedLocatePlayer
end

local function UpdateLocateSort()
    if not selectedLocatePlayer then
        local i = 1
        for _, data in pairs(playerCards) do
            data.Card.LayoutOrder = i
            i += 1
        end
        return
    end

    local targetChar = selectedLocatePlayer.Character
    local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end

    local distances = {}
    for p in pairs(playerCards) do
        local char = p.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        distances[p] = hrp and (hrp.Position - targetHRP.Position).Magnitude or math.huge
    end

    local sorted = {}
    for p in pairs(playerCards) do table.insert(sorted, p) end
    table.sort(sorted, function(a, b)
        return (distances[a] or math.huge) < (distances[b] or math.huge)
    end)

    for i, p in ipairs(sorted) do
        if playerCards[p] then
            playerCards[p].Card.LayoutOrder = i
        end
    end
end

