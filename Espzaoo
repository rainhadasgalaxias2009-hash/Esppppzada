-- ===================== FUNÇÃO DE TWEEN SEGURA =====================
local function playToggleTween(obj, state, tweenVar)
    if not obj then return end

    if tweenVar and tweenVar.PlaybackState == Enum.PlaybackState.Playing then
        tweenVar:Cancel()
    end

    local goal = {
        Position = state and UDim2.new(1, -18, 0, 2) or UDim2.new(0,2,0,2)
    }

    local tween = TweenService:Create(
        obj,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        goal
    )

    tween:Play()
    return tween
end

-- ===================== FUNÇÃO CENTRAL =====================
setGlobalToggle = function(state)
    GLOBAL_TOGGLE = state

    -- 🔥 invalida qualquer execução antiga (RGB + fling)
    RUN_ID += 1

    -- 🔥 tween sincronizado
    toggleTweenMain = playToggleTween(toggleCircle, state, toggleTweenMain)
    toggleTweenTiny = playToggleTween(tinyToggleCircle, state, toggleTweenTiny)

    -- 🔥 desliga visual imediatamente
    if not state then
        if toggleCircle then
            toggleCircle.BackgroundColor3 = Color3.fromRGB(0,0,0)
        end
        if tinyToggleCircle then
            tinyToggleCircle.BackgroundColor3 = Color3.fromRGB(0,0,0)
        end
    end

    -- ================= FLING =================
    if state then
        local myId = RUN_ID

        task.spawn(function()
            while GLOBAL_TOGGLE and myId == RUN_ID do

                if not alive then
                    repeat task.wait(0.2) until alive or not GLOBAL_TOGGLE or myId ~= RUN_ID
                end

                if not GLOBAL_TOGGLE or myId ~= RUN_ID then break end

                local targets = GetSelectedPlayers()
                if #targets == 0 then
                    task.wait(0.2)
                    continue
                end

                for _, target in ipairs(targets) do
                    if not GLOBAL_TOGGLE or myId ~= RUN_ID then break end

                    local char = target.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    local myChar = player.Character
                    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")

                    if hrp and myHrp then
                        -- 🔥 limite aumentado de 5000 para 999999 (sem limite real)
                        if (hrp.Position - myHrp.Position).Magnitude > 999999 then
                            continue
                        end

                        local vel = hrp.AssemblyLinearVelocity

                        -- 🔥 detecta se já foi flingado (velocidade alta)
                        local jaFlingado = vel.Magnitude > 150

                        -- 🔥 detecta se está caindo ou subindo (velocidade vertical significativa)
                        local estaCaindoOuSubindo = math.abs(vel.Y) > 50

                        -- 🔥 detecta se está travado no ar longe (saiu do jogo mas ficou flutuante)
                        -- verifica se o alvo sumiu do Players mas o char ainda existe
                        local alvoPreso = (target.Parent ~= Players) and char ~= nil

                        if jaFlingado or estaCaindoOuSubindo or alvoPreso then
                            continue
                        end

                        pcall(SkidFling, target) -- 🔥 não mata o loop se der erro
                        _flingActive = false      -- 🔥 garante reset mesmo se SafeEnd falhou
                    end
                end

                task.wait()
            end
        end)
    end
end

