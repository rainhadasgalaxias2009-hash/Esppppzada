-- drag
panel.InputBegan:Connect(function(inp)
    if inp.UserInputType ~= Enum.UserInputType.Touch and
       inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    local sp, si, moved, conn = panel.Position, inp.Position, false, nil
    conn = inp.Changed:Connect(function()
        if inp.UserInputState == Enum.UserInputState.Change then
            local d = inp.Position - si
            if not moved and d.Magnitude < 12 then return end
            moved = true
            panel.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        elseif inp.UserInputState == Enum.UserInputState.End then
            conn:Disconnect()
        end
    end)
end)

-- toggle
tog.MouseButton1Click:Connect(function()
    noclipOn = not noclipOn
    if noclipOn then
        circle:TweenPosition(UDim2.fromOffset(28, 2), "Out", "Quad", 0.2, true)
        statusLbl.Text = "ON"; statusLbl.TextColor3 = Color3.fromRGB(80, 255, 80)
        doEnable()
    else
        circle:TweenPosition(UDim2.fromOffset(2, 2), "Out", "Quad", 0.2, true)
        circle.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        statusLbl.Text = "OFF"; statusLbl.TextColor3 = Color3.fromRGB(255, 80, 80)
        doDisable()
    end
end)

-- respawn
player.CharacterAdded:Connect(function()
    origCC = {}
    disconnectNoclip()
    if noclipOn then
        task.wait(0.5)
        doEnable()
        local hum2 = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum2 then hum2.AutoJumpEnabled = false end
    end
end)

