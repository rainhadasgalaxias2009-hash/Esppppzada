local origCC    = {}

local function corner(f, r) Instance.new("UICorner", f).CornerRadius = UDim.new(0, r or 10) end
local function tex(f)
    local t = Instance.new("ImageLabel")
    t.Size = UDim2.fromScale(1,1); t.BackgroundTransparency = 1
    t.Image = "rbxassetid://73012807286736"
    t.ScaleType = Enum.ScaleType.Tile; t.TileSize = UDim2.fromOffset(64,64)
    t.ImageTransparency = 0.20; t.ZIndex = 1; t.Parent = f
    local ec = f:FindFirstChildOfClass("UICorner")
    if ec then local c2 = Instance.new("UICorner"); c2.CornerRadius = ec.CornerRadius; c2.Parent = t end
end
local function strk(f, th)
    local s = Instance.new("UIStroke")
    s.Thickness = th or 2; s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Color = Color3.fromHSV(0,1,1); s.Parent = f; return s
end
local function fsz(l, z)
    l.TextSize = z
    local c = Instance.new("UITextSizeConstraint")
    c.MinTextSize = z; c.MaxTextSize = z; c.Parent = l
end

-- ===== LÓGICA =====
local function disconnectNoclip()
    if noclipConn then
        if type(noclipConn) == "table" then
            for _, c in pairs(noclipConn) do c:Disconnect() end
        else
            noclipConn:Disconnect()
        end
        noclipConn = nil
    end
end

local function doEnable()
    if noclipConn then return end
    local char = player.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    origCC = {}
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then origCC[v] = v.CanCollide end
    end

    hum.AutoJumpEnabled = false

    local function disableCollision()
        local c = player.Character; if not c or not noclipOn then return end
        for _, v in pairs(c:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    local connH = RunService.Heartbeat:Connect(disableCollision)
    local connS = RunService.Stepped:Connect(disableCollision)
    noclipConn = {connH, connS}
end

local function doDisable()
    disconnectNoclip()
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoJumpEnabled = true end
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                local orig = origCC[v]
                if orig ~= nil then pcall(function() v.CanCollide = orig end) end
            end
        end
    end
    origCC = {}
end

