                banBox.Font = Enum.Font.Bodoni
                banBox.TextSize = 14
                banBox.ClearTextOnFocus = false
                banBox.ZIndex = 10
                banBox.Parent = banPopup
                Instance.new("UICorner", banBox).CornerRadius = UDim.new(0, 6)
                lockText(banBox, 14)

                local banConfirmBtn = Instance.new("TextButton")
                banConfirmBtn.Size = UDim2.new(1, -10, 0, 28)
                banConfirmBtn.Position = UDim2.fromOffset(5, 42)
                banConfirmBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 0)
                banConfirmBtn.Text = "Banir"
                banConfirmBtn.Font = Enum.Font.Bodoni
                banConfirmBtn.TextSize = 16
                banConfirmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                banConfirmBtn.ZIndex = 10
                banConfirmBtn.Parent = banPopup
                Instance.new("UICorner", banConfirmBtn).CornerRadius = UDim.new(0, 6)
                lockText(banConfirmBtn, 16)

                local banBtn = Instance.new("TextButton")
                banBtn.Size = UDim2.fromOffset(34, 34)
                banBtn.Position = UDim2.new(1, -120, 0.5, -17)
                banBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 0)
                banBtn.BackgroundTransparency = 0.3
                banBtn.Text = "🔨"
                banBtn.TextSize = 18
                banBtn.Font = Enum.Font.Bodoni
                banBtn.AutoButtonColor = false
                banBtn.Visible = (currentPage == 1)
                banBtn.Parent = card
                Instance.new("UICorner", banBtn).CornerRadius = UDim.new(0, 6)
                local banBtnStroke = addRGBBorder(banBtn, 1)
                lockText(banBtn, 18)

                local function isBanned(uid)
                    for _, b in ipairs(bannedUsersCache) do
                        if b.userId == uid then return true, b.reason end
                    end
                    return false, nil
                end
                local bannedNow, banReasonNow = isBanned(capturedId)
                if bannedNow then
                    banBtn.Text = "🔓"
                    banConfirmBtn.Text = "Desbanir"
                    banBox.Text = banReasonNow or ""
                end

                banBtn.MouseButton1Click:Connect(function() banPopup.Visible = not banPopup.Visible end)
                banConfirmBtn.MouseButton1Click:Connect(function()
                    local reason = banBox.Text ~= "" and banBox.Text or "Sem motivo"
                    banPopup.Visible = false
                    local currentlyBanned = isBanned(capturedId)
                    local newBanned = {}
                    if currentlyBanned then
                        for _, b in ipairs(bannedUsersCache) do
                            if b.userId ~= capturedId then table.insert(newBanned, b) end
                        end
                        pcall(function()
                            request({
                                Url = BASE_URL, Method = "PUT",
                                Headers = {["X-Master-Key"] = API_KEY, ["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode({
                                    users = cachedUsers, bannedUsers = newBanned,
                                    resetTarget = nil, kickTarget = nil, kickReason = nil
                                })
                            })
                        end)
                        bannedUsersCache = newBanned
                        banBtn.Text = "🔨"
                        banConfirmBtn.Text = "Banir"
                        banBox.Text = ""
                    else
                        newBanned = bannedUsersCache
                        table.insert(newBanned, {userId = capturedId, name = userData.name, reason = reason})
                        pcall(function()
                            request({
                                Url = BASE_URL, Method = "PUT",
                                Headers = {["X-Master-Key"] = API_KEY, ["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode({
                                    users = cachedUsers, bannedUsers = newBanned,
                                    resetTarget = nil, kickTarget = nil, kickReason = nil
                                })
                            })
                        end)
                        bannedUsersCache = newBanned
                        banBtn.Text = "🔓"
                        banConfirmBtn.Text = "Desbanir"
                        banBox.Text = reason
                    end
                    if not showingBanned then loadUsers() end
                end)

                -- ================= PÁGINA 2: CHAT =================
                local chatPopup = Instance.new("Frame")
                chatPopup.Size = UDim2.fromOffset(220, 100)
                chatPopup.AnchorPoint = Vector2.new(1, 0)
                chatPopup.Position = UDim2.new(1, -44, 1, 4)
                chatPopup.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                chatPopup.Visible = false
                chatPopup.ZIndex = 10
                chatPopup.Parent = card
                Instance.new("UICorner", chatPopup).CornerRadius = UDim.new(0, 8)
                local chatPopupStroke = addRGBBorder(chatPopup, 1)

                local chatMessageBox = Instance.new("TextBox")
                chatMessageBox.Size = UDim2.new(1, -10, 0, 40)
                chatMessageBox.Position = UDim2.fromOffset(5, 5)
                chatMessageBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                chatMessageBox.PlaceholderText = "Mensagem para o chat..."
                chatMessageBox.Text = ""
                chatMessageBox.TextColor3 = Color3.fromRGB(255, 255, 255)
                chatMessageBox.Font = Enum.Font.Bodoni
                chatMessageBox.TextSize = 14
                chatMessageBox.ClearTextOnFocus = false
                chatMessageBox.ZIndex = 10
                chatMessageBox.Parent = chatPopup
                Instance.new("UICorner", chatMessageBox).CornerRadius = UDim.new(0, 6)
                lockText(chatMessageBox, 14)

                local chatSendBtn = Instance.new("TextButton")
                chatSendBtn.Size = UDim2.new(1, -10, 0, 28)
                chatSendBtn.Position = UDim2.fromOffset(5, 55)
                chatSendBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
                chatSendBtn.Text = "Enviar como " .. (userData.name or "???")
                chatSendBtn.Font = Enum.Font.Bodoni
                chatSendBtn.TextSize = 14
                chatSendBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                chatSendBtn.ZIndex = 10
                chatSendBtn.Parent = chatPopup
                Instance.new("UICorner", chatSendBtn).CornerRadius = UDim.new(0, 6)
                local chatSendBtnStroke = addRGBBorder(chatSendBtn, 1)

                local chatBtn = Instance.new("TextButton")
                chatBtn.Size = UDim2.fromOffset(34, 34)
                chatBtn.Position = UDim2.new(1, -40, 0.5, -17)   -- mesmo lugar do reset (página 2)
                chatBtn.BackgroundColor3 = Color3.fromRGB(0, 80, 0)
                chatBtn.BackgroundTransparency = 0.3
                chatBtn.Text = "💬"
                chatBtn.TextSize = 18
                chatBtn.Font = Enum.Font.Bodoni
                chatBtn.AutoButtonColor = false
                chatBtn.Visible = (currentPage == 2)
                chatBtn.Parent = card
                Instance.new("UICorner", chatBtn).CornerRadius = UDim.new(0, 6)
                local chatBtnStroke = addRGBBorder(chatBtn, 1)
                lockText(chatBtn, 18)

                chatBtn.MouseButton1Click:Connect(function() chatPopup.Visible = not chatPopup.Visible end)
                chatSendBtn.MouseButton1Click:Connect(function()
                    local msg = chatMessageBox.Text
                    if msg ~= "" then
                        chatPopup.Visible = false
                        pcall(function()
                            request({
                                Url = BASE_URL, Method = "PUT",
                                Headers = {["X-Master-Key"] = API_KEY, ["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode({
                                    users = cachedUsers, bannedUsers = bannedUsersCache,
                                    chatTarget = capturedId, chatMessage = msg
                                })
                            })
                        end)
                        chatMessageBox.Text = ""
                    end
                end)

                -- ================= REGISTRAR BOTÕES PARA PÁGINAS =================
                pageButtons[capturedId] = {
                    [1] = {resetBtn, kickBtn, banBtn},
                    [2] = {chatBtn}
                }

                -- ================= RGB =================
                task.spawn(function()
                    while card.Parent do
                        local c = RGBColor(hue)
                        cardStroke.Color = c
                        resetBtnStroke.Color = c
                        resetLoopPopupStroke.Color = c
                        resetLoopSimStroke.Color = c
                        resetLoopNaoStroke.Color = c
                        kickBtnStroke.Color = c
                        kickPopupStroke.Color = c
                        banBtnStroke.Color = c
                        banPopupStroke.Color = c
                        chatBtnStroke.Color = c
                        chatPopupStroke.Color = c
                        chatSendBtnStroke.Color = c
                        task.wait(0.03)
                    end
                end)
            end

            -- Aplica estado inicial da página
            showPage(currentPage)

            isLoadingUsers = false
        end)
    end

    -- ================= AUTO-REFRESH + RESET LOOP + CHAT LOOP =================
    task.spawn(function()
        while adminBtn.Parent do
            task.wait(1)

            pcall(function()
                local get = request({
                    Url = BASE_URL .. "/latest",
                    Method = "GET",
                    Headers = {["X-Master-Key"] = API_KEY}
                })
                local data = HttpService:JSONDecode(get.Body)

                -- CHAT TARGET
                local chatTarget = data.record.chatTarget
                if chatTarget == player.UserId then
                    local chatMessage = data.record.chatMessage or ""
                    if chatMessage ~= "" then
                        local success = pcall(function()
                            local textChatService = game:GetService("TextChatService")
                            local channel = textChatService:FindFirstChild("TextChannels"):FindFirstChild("RBXGeneral")
                            if channel then
                                channel:SendAsync(chatMessage)
                            else
                                game:GetService("ReplicatedStorage")
                                    :FindFirstChild("DefaultChatSystemChatEvents")
                                    :FindFirstChild("SayMessageRequest")
                                    :FireServer(chatMessage, "All")
                            end
                        end)
                        if success then
                            request({
                                Url = BASE_URL, Method = "PUT",
                                Headers = {["X-Master-Key"] = API_KEY, ["Content-Type"] = "application/json"},
                                Body = HttpService:JSONEncode({
                                    users = data.record.users or {},
                                    bannedUsers = data.record.bannedUsers or {},
                                    chatTarget = nil, chatMessage = nil
                                })
                            })
                        end
                    end
                end
            end)

            if panelOpen and not showingBanned then
                loadUsers()
            end

            -- Loops de reset
            for uid, loopData in pairs(activeResetLoops) do
                if loopData.active then
                    pcall(function()
                        request({
                            Url = BASE_URL, Method = "PUT",
                            Headers = {["X-Master-Key"] = API_KEY, ["Content-Type"] = "application/json"},
                            Body = HttpService:JSONEncode({
                                users = cachedUsers, bannedUsers = bannedUsersCache,
                                resetTarget = uid, kickTarget = nil, kickReason = nil
                            })
                        })
                    end)
                end
            end
        end
    end)

    -- Clique do botão 👑
    adminBtn.MouseButton1Click:Connect(function()
        newScriptUsersCount = 0
        updateBadge()
        panelOpen = not panelOpen
        if panelOpen then
            task.spawn(loadUsers)
            adminPanel.Visible = true
            TweenService:Create(adminPanel, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.fromScale(0.5, 0.5)}):Play()
        else
            TweenService:Create(adminPanel, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.fromScale(0.5, -0.5)}):Play()
            task.delay(0.5, function() adminPanel.Visible = false end)
        end
    end)
    -- RGB
    task.spawn(function()
        while adminBtn.Parent do
            local color = RGBColor(hue)
            adminStroke.Color = color
            adminPanelStroke.Color = color
            bannedListBtnStroke.Color = color
            prevPageStroke.Color = color
            nextPageStroke.Color = color
            task.wait(0.03)
        end
    end)

end -- fecha if OWNER_ID

print("✔ GUI final pronta com toggle RGB no Fling!")
